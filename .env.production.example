# ─── Production (VPS) ────────────────────────────────────────────────────────
# Salin ke .env lalu isi. NEXT_PUBLIC_* di-inline saat build (rebuild jika ganti).
NEXT_PUBLIC_SITE_URL=https://automotive.yuandewatatimur.com
# Base URL backend TANPA `/api` dan TANPA trailing slash.
NEXT_PUBLIC_API_URL=https://apiautomotive.yuandewatatimur.com

# Harus identik dengan REVALIDATE_SECRET di backend.
REVALIDATE_SECRET=shared-secret-with-frontend

# Google Analytics 4 — measurement ID (format G-XXXXXXXXXX).
# Di-inline saat build: ganti nilai = wajib rebuild image, bukan sekadar restart.
# Kosongkan untuk mematikan tracking sepenuhnya.
NEXT_PUBLIC_GA_ID=G-20G8G6ZKD8
