# ─── Lokal / development ─────────────────────────────────────────────────────
# Salin ke .env.local lalu isi. FE di :3000, BE (NestJS) di :3001.
# NEXT_PUBLIC_API_URL = base URL backend TANPA `/api` dan TANPA trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Harus identik dengan REVALIDATE_SECRET di backend (untuk webhook ISR).
REVALIDATE_SECRET=shared-secret-with-frontend

# Google Analytics 4 — sengaja DIKOSONGKAN di lokal agar traffic development
# tidak masuk ke laporan produksi. Isi sementara (G-XXXXXXXXXX) hanya bila
# memang sedang menguji integrasi GA, lalu kosongkan lagi.
# NEXT_PUBLIC_GA_ID=
